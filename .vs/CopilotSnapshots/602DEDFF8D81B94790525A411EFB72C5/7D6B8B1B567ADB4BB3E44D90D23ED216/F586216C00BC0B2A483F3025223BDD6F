using Sistema.Clases;
using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace Sistema.Formularios.FormDentistas
{
    public partial class EspecialidadesForm : Form
    {
        // Controladores y Servicios
        ConsultasSQL consulta = new ConsultasSQL();
        AlertasDelSistema Alertas = new AlertasDelSistema();

        string operacion = ""; // "Agregando" o "Editando"

        public EspecialidadesForm()
        {
            InitializeComponent();
            MostrarEspecialidades();
        }

        /// <summary>
        /// Muestra la lista de especialidades en el DataGridView
        /// </summary>
        private void MostrarEspecialidades()
        {
            try
            {
                DataTable dt = consulta.Buscar("Especialidades", "Id_Especialidad, Nombre, Descripcion");

                if (dt != null && dt.Rows.Count > 0)
                {
                    dgvEspecialidades.DataSource = dt;
                    dgvEspecialidades.AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill;
                    dgvEspecialidades.Refresh();
                }
                else
                {
                    dgvEspecialidades.DataSource = null;
                    Alertas.Advertencia("No hay especialidades registradas.");
                }
            }
            catch (Exception ex)
            {
                Alertas.Advertencia($"Error al mostrar especialidades: {ex.Message}");
            }
        }

        /// <summary>
        /// Recopia los datos del formulario y llama al controlador de guardado
        /// </summary>
        private void CompartirDatos()
        {
            try
            {
                // Validar campos no vacíos
                if (string.IsNullOrEmpty(txtNombre.Text.Trim()) ||
                    string.IsNullOrEmpty(txtDescripcion.Text.Trim()))
                {
                    Alertas.Advertencia("Por favor, complete todos los campos.");
                    return;
                }

                int idEspecialidad = string.IsNullOrEmpty(txtID.Text) ? 0 : Convert.ToInt32(txtID.Text);
                string nombre = txtNombre.Text.Trim();
                string descripcion = txtDescripcion.Text.Trim();

                GuardarEspecialidad(idEspecialidad, nombre, descripcion);
            }
            catch (Exception ex)
            {
                Alertas.Advertencia($"Error al procesar datos: {ex.Message}");
            }
        }

        /// <summary>
        /// Guarda o actualiza una especialidad en la BD
        /// </summary>
        private void GuardarEspecialidad(int id, string nombre, string descripcion)
        {
            try
            {
                string sql = "";

                if (operacion == "Editando")
                {
                    sql = $@"UPDATE Especialidades
                             SET Nombre = @Nombre,
                                 Descripcion = @Descripcion
                             WHERE Id_Especialidad = {id}";
                }
                else
                {
                    sql = $@"INSERT INTO Especialidades
                             (Nombre, Descripcion)
                             VALUES
                             (@Nombre, @Descripcion)";
                }

                using (var cmd = new System.Data.SqlClient.SqlCommand(sql))
                {
                    cmd.Parameters.AddWithValue("@Nombre", nombre);
                    cmd.Parameters.AddWithValue("@Descripcion", descripcion);

                    int filas = consulta.EjecutarComando(cmd);

                    if (filas > 0)
                    {
                        string mensaje = operacion == "Editando" ? "actualizo" : "guardo";
                        Alertas.Realizado($"Especialidad '{nombre}' se {mensaje} correctamente.");
                        LimpiarCampos();
                        MostrarEspecialidades();
                    }
                }
            }
            catch (Exception ex)
            {
                Alertas.Advertencia($"Error al guardar especialidad: {ex.Message}");
            }
        }

        /// <summary>
        /// Limpia todos los campos del formulario
        /// </summary>
        private void LimpiarCampos()
        {
            txtID.Text = string.Empty;
            txtNombre.Text = string.Empty;
            txtDescripcion.Text = string.Empty;
            operacion = "Agregando";
        }

        /// <summary>
        /// Carga los datos de una especialidad al hacer doble clic en la tabla
        /// </summary>
        private void EnviarDatosParaEditar(DataGridViewCellEventArgs e)
        {
            try
            {
                if (e.RowIndex >= 0)
                {
                    DataGridViewRow fila = dgvEspecialidades.Rows[e.RowIndex];
                    operacion = "Editando";

                    txtID.Text = fila.Cells["Id_Especialidad"].Value?.ToString() ?? "";
                    txtNombre.Text = fila.Cells["Nombre"].Value?.ToString() ?? "";
                    txtDescripcion.Text = fila.Cells["Descripcion"].Value?.ToString() ?? "";
                }
            }
            catch (Exception ex)
            {
                Alertas.Advertencia($"Error al cargar datos: {ex.Message}");
            }
        }

        // Event Handlers
        private void btnGuardar_Click(object sender, EventArgs e)
        {
            CompartirDatos();
        }

        private void btnCancelar_Click(object sender, EventArgs e)
        {
            LimpiarCampos();
            MostrarEspecialidades();
        }

        private void dgvEspecialidades_CellDoubleClick(object sender, DataGridViewCellEventArgs e)
        {
            EnviarDatosParaEditar(e);
        }
    }
}
